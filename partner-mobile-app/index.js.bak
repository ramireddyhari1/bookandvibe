import { registerRootComponent } from 'expo';
import { ExpoRoot } from 'expo-router';

// The entry point for Expo Router is usually automatic via expo-router/entry.
// However, in experimental builds or monorepos on Windows, manual initialization
// is much more robust as it allows us to explicitly define the route context.
export function App() {
  const ctx = require.context('./src/app');
  return <ExpoRoot context={ctx} />;
}

registerRootComponent(App);
